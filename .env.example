# Anthropic (agent chat API)
ANTHROPIC_API_KEY=

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server-only — required for Stripe webhooks + billing writes
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — Dashboard → Developers → API keys + Products
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App URL for Stripe redirects (production)
NEXT_PUBLIC_APP_URL=https://daywinner.bot

# Optional: block the app until users sign in (auto-enabled when Stripe billing is configured)
# NEXT_PUBLIC_REQUIRE_AUTH=true

# Set to true to skip the paywall (dev/preview). Omit or false when Stripe keys are set.
# NEXT_PUBLIC_DISABLE_PAYWALL=true
# Server-only override: DISABLE_PAYWALL=true

# Setup checklist:
# 1. Run supabase/migrations/001_profiles.sql then 002_billing.sql in Supabase SQL Editor
# 2. Auth → Providers → enable Email
# 3. Auth → URL Configuration → Site URL = https://daywinner.bot
# 4. Redirect URLs: https://daywinner.bot/auth/callback
# 5. Stripe → Product $4.99/mo → copy Price ID to STRIPE_PRICE_ID
# 6. Stripe → Webhooks → endpoint https://daywinner.bot/api/stripe/webhook
#    Events: checkout.session.completed, customer.subscription.created/updated/deleted
# 7. Add all env vars to Vercel, redeploy
