# Anthropic (existing chat API)
ANTHROPIC_API_KEY=

# Supabase — Project Settings → API (https://supabase.com/dashboard)
# Use the project URL only (no /rest/v1 path) or Kong may return {"error":"requested path is invalid"}
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: server-only admin operations (never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=
